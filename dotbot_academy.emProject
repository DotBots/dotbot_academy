      debug_stack_pointer_start="__stack_end__"
      debug_start_from_entry_point_symbol="No"
      debug_target_connection="J-Link"
      gcc_entry_point="Reset_Handler"
      link_linker_script_file="$(ProjectDir)/../common/system/nRF_Flash_Variant3.icf"
      linker_memory_map_file="$(ProjectDir)/../common/system/nRF5340_xxAA_Network_MemoryMap.xml"
      macros="DeviceHeaderFile=$(PackagesDir)/../common/system/nRF/Device/Include/nrf.h;DeviceSystemFile=$(PackagesDir)/../common/system/nRF/Device/Source/system_nrf5340_network.c;DeviceVectorsFile=$(PackagesDir)/../common/system/nRF/Source/nrf5340_network_Vectors.s;DeviceFamily=nRF;Target=nRF5340_xxAA_Network"
      project_directory="00std_nrf5340-dk_buttons"
      project_type="Executable"
      target_reset_script="Reset();" />
    <folder Name="CMSIS Files">
      <file file_name="../common/system/nRF/Device/Include/nrf.h" />
      <file file_name="../common/system/nRF/Device/Source/system_nrf5340_network.c">
        <configuration
          Name="Common"
          default_code_section=".init"
          default_const_section=".init_rodata" />
      </file>
    </folder>
    <folder Name="Script Files">

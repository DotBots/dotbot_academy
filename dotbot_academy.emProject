      </file>
    </folder>
    <folder Name="Source Files">
      <configuration Name="Common" filter="c;cpp;cxx;cc;h;s;asm;inc" />
      <file file_name="00std_nrf5340-dk_buttons.c" />
    </folder>
    <folder Name="System Files">
